<?xml version="1.0" encoding="utf-8"?>
<!--
  Dev-mode package identity for the work-dash windows client.

  UserNotificationListener's NotificationChanged event fails with
  0x80070490 ("Element not found") unless the calling process has package
  identity. This manifest is registered loose ("Add-AppxPackage -Register")
  from the cargo target\debug directory — see register.ps1 — so the plain
  cargo-built exes gain identity without a signed MSIX. Requires Windows
  Developer Mode.
-->
<Package
    xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
    xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
    xmlns:uap10="http://schemas.microsoft.com/appx/manifest/uap/windows10/10"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
    IgnorableNamespaces="uap uap3 uap10 rescap">

  <Identity Name="WorkDash.WindowsClient"
            Publisher="CN=WorkDash Dev"
            Version="0.1.0.0"
            ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>work-dash windows client (dev)</DisplayName>
    <PublisherDisplayName>cgpp</PublisherDisplayName>
    <Logo>Assets\logo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop"
                        MinVersion="10.0.19041.0"
                        MaxVersionTested="10.0.26200.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="ToastLogger"
                 Executable="toast_logger.exe"
                 uap10:TrustLevel="mediumIL"
                 uap10:RuntimeBehavior="packagedClassicApp">
      <uap:VisualElements DisplayName="work-dash toast logger"
                          Description="Logs toast notifications for calibration"
                          BackgroundColor="transparent"
                          Square150x150Logo="Assets\logo.png"
                          Square44x44Logo="Assets\logo.png"
                          AppListEntry="none" />
    </Application>
    <Application Id="WorkDashClient"
                 Executable="work-dash-windows-client.exe"
                 uap10:TrustLevel="mediumIL"
                 uap10:RuntimeBehavior="packagedClassicApp">
      <uap:VisualElements DisplayName="work-dash windows client"
                          Description="Pushes Outlook calendar and Teams calls to work-dash-server"
                          BackgroundColor="transparent"
                          Square150x150Logo="Assets\logo.png"
                          Square44x44Logo="Assets\logo.png"
                          AppListEntry="none" />
    </Application>
  </Applications>

  <Capabilities>
    <!-- Required for UserNotificationListener — without it,
         NotificationChanged fails with 0x80070490 "Element not found". -->
    <uap3:Capability Name="userNotificationListener" />
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
